{
  "name": "audit-canvas",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, Git-aware audit workbench for software artifacts.",
  "license": "MIT",
  "author": "duiliang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duiliang/audit-canvas.git"
  },
  "homepage": "https://github.com/duiliang/audit-canvas#readme",
  "bugs": {
    "url": "https://github.com/duiliang/audit-canvas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "build": "pnpm -r build && pnpm build:plugin",
    "build:plugin": "node scripts/build-plugin-cli.mjs",
    "lint": "eslint .",
    "typecheck": "pnpm build && pnpm -r typecheck",
    "test": "pnpm build:plugin && vitest run",
    "test:coverage": "pnpm build:plugin && vitest run --coverage",
    "test:e2e": "playwright test",
    "verify:generated": "git diff --exit-code -- plugins/codex-audit-canvas/scripts/audit-canvas-cli.mjs",
    "validate:plugin": "node scripts/validate-plugin.mjs",
    "validate:marketplace": "node scripts/validate-marketplace.mjs",
    "validate:release": "node scripts/validate-release.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "3.2.7",
    "esbuild": "0.28.1",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4"
  }
}
